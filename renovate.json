{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": ["gitlabci", "gitlabci-include", "pep621", "dockerfile"],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchPackageNames": ["pytest", "pytest-cov", "pytest-mock", "requests-mock", "tox", "pylint", "bandit"],
      "additionalBranchPrefix": "test-",
      "automerge": true
    },
    {
      "matchManagers": ["pep621", "dockerfile"],
      "matchPackageNames": ["!pytest", "!pytest-cov", "!pytest-mock", "!requests-mock", "!tox", "!pylint", "!bandit"],
      "additionalBranchPrefix": "dev-"
    }
  ]
}
